# Auto-detect text files and ensure LF line endings
* text=auto eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Data formats
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Web/Code
*.js text eol=lf
*.ts text eol=lf
*.py text eol=lf
*.css text eol=lf
*.html text eol=lf

# Config files
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.gif binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
