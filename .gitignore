# ===================================================
# ~/.claude/ Knowledge Hub - Granulare Component Whitelist
# ===================================================
# Strategy: Ignore EVERYTHING, then whitelist EACH
# component by name. .gitignore = Living Manifest.
#
# Neue Components hinzufuegen: 2 Zeilen pro Skill/Plugin,
# 1 Zeile pro Agent/Command/Hook/Rule/Style.
# ===================================================

# Ignore everything by default
*

# ===== GIT CONFIG & TOOLING (pauschal) =====
!.gitignore
!.gitattributes
!.editorconfig
!.markdownlint.jsonc

# ===== GLOBAL CLAUDE INSTRUCTIONS =====
!CLAUDE.md

# ===== COMMUNITY STANDARD FILES =====
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!CHANGELOG.md

# ===== GITHUB CONFIG =====
!.github/
!.github/**

# ===== SKILLS (je 2 Zeilen: Ordner + Inhalt) =====
!skills/
# --- Session & Docs ---
!skills/session-refresh/
!skills/session-refresh/**
!skills/project-init/
!skills/project-init/**
!skills/project-doc-restructure/
!skills/project-doc-restructure/**
!skills/claude-md-restructure/
!skills/claude-md-restructure/**
# --- Task Management ---
!skills/task-scheduler/
!skills/task-scheduler/**
!skills/task-orchestrator/
!skills/task-orchestrator/**
!skills/prioritize-tasks/
!skills/prioritize-tasks/**
# --- Git & GitHub ---
!skills/github-push/
!skills/github-push/**
!skills/github-init/
!skills/github-init/**
!skills/github-ops/
!skills/github-ops/**
!skills/github-status/
!skills/github-status/**
# --- Prompt & Skill Engineering ---
!skills/prompt-improver/
!skills/prompt-improver/**
!skills/skill-creator/
!skills/skill-creator/**
# --- Audit & Ops ---
!skills/permission-audit/
!skills/permission-audit/**
# --- ENTFERNT (nicht mehr whitelisten) ---
# skills/granola-export — leer, geloescht
# skills/prompt-architect — Agent war redundant (kein Skill, nur Referenz)

# ===== AGENTS (je 1 Zeile) =====
!agents/
!agents/my-setup-guide.md
# ENTFERNT: agents/prompt-architect.md — redundant zu prompt-improver Skill

# ===== COMMANDS (je 1 Zeile) =====
!commands/
!commands/run-next-tasks.md
!commands/statusline.sh

# ===== HOOKS (je 1 Zeile) =====
!hooks/
!hooks/auto-approve-readonly.sh
!hooks/notify.sh
!hooks/session-handoff-loader.sh
!hooks/session-start-scheduler.sh

# ===== RULES (je 1 Zeile) =====
!rules/

# ===== OUTPUT STYLES (je 1 Zeile) =====
!output-styles/

# ===== PLUGINS (self-developed, einzeln) =====
!plugins/
!plugins/cache/
!plugins/cache/local-plugins/
!plugins/cache/local-plugins/ai-visualisation/
!plugins/cache/local-plugins/ai-visualisation/**
!plugins/cache/local-plugins/auto-task/
!plugins/cache/local-plugins/auto-task/**

# ===== DOCS & ASSETS =====
!assets/
!assets/claude-icon.png

# ===== SECRETS SETUP (Example Files Only) =====
!secrets-setup/
!secrets-setup/**

# ===== EXPLICIT DENIES (Safety Net) =====
# Credentials and secrets
.credentials.json
settings.json
settings.local.json
mcp.json
*.env
!*.env.example
*.secret
*.token

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.cert
id_rsa*
id_ed25519*
id_ecdsa*

# Session data (large, ephemeral)
history.jsonl
session-env/
file-history/
debug/
plans/
/cache/
paste-cache/
shell-snapshots/
backups/
plugins/cache/marketplace/
plugins/installed_plugins.json
projects/
security_warnings_state_*.json

# Permission-Audit Logs (generated at runtime by hook)
skills/permission-audit/artifacts/*.log

# Build artifacts
__pycache__/
*.pyc

# WSL Zone Identifier metadata
*:Zone.Identifier
