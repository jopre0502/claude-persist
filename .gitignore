# ===================================================
# claude-persist - Plugin-Repo Gitignore
# ===================================================
# Strategy: Whitelist Plugin-Komponenten + Community-Files,
# blacklist sensible Files (Defense-in-Depth).
#
# Repo-Aera: Plugin-only (seit 2026-05-19 via /pt:release-persist-public).
# Sweep + Whitelist-Copy filtert beim Release — diese Gitignore
# ist nur die letzte Sicherheitsschicht.
# ===================================================

# Ignore everything by default
*

# ===== GIT CONFIG & TOOLING =====
!.gitignore
!.gitattributes
!.editorconfig
!.markdownlint.jsonc

# ===== COMMUNITY STANDARD FILES =====
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!CHANGELOG.md

# ===== GITHUB CONFIG =====
!.github/
!.github/**

# ===== PLUGIN MANIFEST =====
!.claude-plugin/
!.claude-plugin/**

# ===== PLUGIN COMPONENTS (Whitelist pauschal) =====
!skills/
!skills/**
!commands/
!commands/**
!hooks/
!hooks/**
!scripts/
!scripts/**

# ===== EXPLICIT DENIES (Safety Net) =====
# Credentials and secrets
.credentials.json
settings.json
settings.local.json
mcp.json
*.env
!*.env.example
*.secret
*.token

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.cert
id_rsa*
id_ed25519*
id_ecdsa*

# Build artifacts
__pycache__/
*.pyc

# Session data (Hub-only, never in Public)
history.jsonl
session-env/
file-history/
debug/
plans/
/cache/
paste-cache/
shell-snapshots/
backups/
plugins/cache/
plugins/installed_plugins.json
projects/
security_warnings_state_*.json

# WSL Zone Identifier metadata
*:Zone.Identifier
