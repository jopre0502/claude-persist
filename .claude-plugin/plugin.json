{
  "name": "persist",
  "description": "Session-Continuity Framework: Task scheduling, session refresh, project initialization, documentation management, and deterministic git-safety guards for Claude Code.",
  "version": "1.5.0",
  "author": {
    "name": "Jonas Prechtel"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-handoff-loader.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/git-safety-guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
